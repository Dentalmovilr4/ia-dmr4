{
  "name": "ia-dmr4",
  "version": "1.1.0",
  "description": "Sistema inteligente de gestión de procesos autónomos (IA-DMR4)",
  "main": "server.js",
  "type": "commonjs",

  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "restart": "pkill -f server.js && node server.js",
    "logs": "tail -f estado.json",
    "clean": "rm -f estado.json estado.json.bak estado.json.tmp"
  },

  "keywords": [
    "process-manager",
    "automation",
    "ai",
    "bot-manager",
    "dmr4"
  ],

  "author": "Dentalmovilr4",
  "license": "ISC",

  "engines": {
    "node": ">=18"
  },

  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "@supabase/supabase-js": "^2.103.0",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "qrcode": "^1.5.4"
  },

  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
